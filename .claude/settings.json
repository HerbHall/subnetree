{
  "permissions": {
    "allow": [
      "Bash(git:*)",
      "Bash(gh:*)",
      "Bash(make:*)",
      "Bash(npx:*)",
      "Bash(go:*)",
      "Bash(python:*)",
      "Bash(python3:*)",
      "Bash(node:*)",
      "Bash(docker:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(grep:*)",
      "Bash(find:*)",
      "Bash(mkdir:*)",
      "Bash(cp:*)",
      "Bash(mv:*)",
      "Bash(echo:*)",
      "Bash(pwd:*)",
      "Bash(which:*)",
      "Bash(command:*)",
      "Bash(wc:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(sort:*)",
      "Bash(uniq:*)",
      "Bash(diff:*)",
      "Bash(test:*)",
      "Bash(bash:*)",
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep",
      "Task",
      "Skill",
      "WebFetch",
      "WebSearch",
      "mcp__*"
    ],
    "deny": [
      "Bash(rm -rf /)"
    ]
  },
  "enableAllProjectMcpServers": true,
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo 'AUTO_START: Run /dashboard skill to display the session control station with project state, priorities, and available actions.'"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "^(?!/).{15,}",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'Reminder: Coordination files at .coordination/. Use /dashboard option 10 for research requests.'"
          }
        ]
      }
    ]
  }
}
